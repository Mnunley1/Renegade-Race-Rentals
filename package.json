{
  "name": "renegade-monorepo",
  "version": "1.0.0",
  "description": "Renegade Race Track Rental Platform - Monorepo",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "dev": "pnpm --recursive --parallel run dev",
    "build": "pnpm --recursive run build",
    "lint": "pnpm --recursive run lint",
    "lint:fix": "pnpm --recursive run lint:fix",
    "type-check": "pnpm --recursive run type-check",
    "clean": "pnpm --recursive run clean",
    "install:all": "pnpm install",
    "convex:dev": "cd packages/backend && pnpm convex:dev",
    "convex:deploy": "cd packages/backend && pnpm convex:deploy",
    "seed:motorsports": "node seed-motorsports.js",
    "mobile:dev": "pnpm --filter=racetrack-rental-app run dev",
    "web:dev": "pnpm --filter=renegade-race-rentals run dev",
    "admin:dev": "pnpm --filter=vite-react-typescript-starter run dev",
    "mobile:build": "pnpm --filter=racetrack-rental-app run build:web",
    "web:build": "pnpm --filter=renegade-race-rentals run build",
    "admin:build": "pnpm --filter=vite-react-typescript-starter run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "prettier": "^3.3.0",
    "typescript": "^5.6.2"
  }
}
