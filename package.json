{
  "name": "renegade-monorepo",
  "version": "1.0.0",
  "description": "Renegade Race Track Rental Platform - Monorepo",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "install:all": "pnpm install",
    "convex:dev": "cd packages/backend && pnpm convex:dev",
    "convex:deploy": "cd packages/backend && pnpm convex:deploy",
    "seed:motorsports": "node seed-motorsports.js",
    "mobile:dev": "turbo run dev --filter=renegade-race-app",
    "web:dev": "turbo run dev --filter=renegade-race-rentals",
    "admin:dev": "turbo run dev --filter=renegade-rentals-admin",
    "mobile:build": "turbo run build --filter=renegade-race-app",
    "web:build": "turbo run build --filter=renegade-race-rentals",
    "admin:build": "turbo run build --filter=renegade-rentals-admin"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "prettier": "^3.3.0",
    "turbo": "^2.5.8",
    "typescript": "^5.6.2"
  }
}
