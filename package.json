{
  "name": "renegade-monorepo",
  "version": "1.0.0",
  "description": "Renegade Race Track Rental Platform - Monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "install:all": "pnpm install",
    "convex:dev": "turbo run convex:dev --filter=@renegade/backend",
    "convex:deploy": "turbo run convex:deploy --filter=@renegade/backend",
    "convex:mcp": "turbo run convex:mcp --filter=@renegade/backend",
    "seed:motorsports": "node seed-motorsports.js",
    "web:dev": "turbo run dev --filter=renegade-web-app",
    "admin:dev": "turbo run dev --filter=renegade-admin-app",
    "web:build": "turbo run build --filter=renegade-web-app",
    "admin:build": "turbo run build --filter=renegade-admin-app",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.3.0",
    "turbo": "^2.5.8",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "apps/renegade-web-app/**/*.{ts,tsx}": [
      "cd apps/renegade-web-app && eslint --fix",
      "prettier --write"
    ],
    "apps/renegade-admin-app/**/*.{ts,tsx}": [
      "cd apps/renegade-admin-app && eslint --fix",
      "prettier --write"
    ],
    "packages/ui/**/*.{ts,tsx}": [
      "cd packages/ui && eslint --fix",
      "prettier --write"
    ],
    "packages/backend/**/*.{ts,tsx}": [
      "cd packages/backend && eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
