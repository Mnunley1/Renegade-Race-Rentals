# Ignore other apps in monorepo
apps/mobile-app/
apps/admin-app/

# Ignore development files
*.md
*.log
.env.local
.env.development.local
.env.test.local

# Ignore build artifacts from other apps
apps/*/dist/
apps/*/build/
apps/*/node_modules/

# Ignore iOS/Android specific files
apps/*/ios/
apps/*/android/

# Ignore test files
**/*.test.*
**/*.spec.*
__tests__/
coverage/

# Ignore documentation
docs/
*.md
