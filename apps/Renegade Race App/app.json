{
  "expo": {
    "name": "Renegade",
    "slug": "renegade-race-rentals",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.racerentals.auto",
      "requiresFullScreen": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app uses the camera to allow users to take and upload photos of their vehicles.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to allow you to select and upload profile pictures."
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "83dd10ec-395b-46c4-8f86-70c2255d401a"
      }
    },
    "owner": "renegade_race_rentals",
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.racerentals.auto",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/83dd10ec-395b-46c4-8f86-70c2255d401a"
    }
  }
}
