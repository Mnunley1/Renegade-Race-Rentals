## Code Examples

### Proper Component Example

```typescript
import React from 'react';
import { View, Text, TouchableOpacity } from 'react-native';
import { useQuery } from 'convex/react';
import { api } from '@/convex/_generated/api';

interface CarCardProps {
  carId: string;
  onPress: (carId: string) => void;
}

export default function CarCard({ carId, onPress }: CarCardProps) {
  const car = useQuery(api.vehicles.get, { id: carId });

  if (!car) {
    return <View><Text>Loading...</Text></View>;
  }

  return (
    <TouchableOpacity onPress={() => onPress(carId)}>
      <View>
        <Text>{car.name}</Text>
        <Text>{car.description}</Text>
      </View>
    </TouchableOpacity>
  );
}
```

### Proper Convex Function Example

```typescript
import { mutation } from './_generated/server';
import { v } from 'convex/values';

export const createReservation = mutation({
  args: {
    vehicleId: v.id('vehicles'),
    startDate: v.string(),
    endDate: v.string(),
  },
  handler: async (ctx, args) => {
    const identity = await ctx.auth.getUserIdentity();
    if (!identity) {
      throw new Error('Not authenticated');
    }

    // Validate input
    if (new Date(args.startDate) >= new Date(args.endDate)) {
      throw new Error('Invalid date range');
    }

    // Check availability
    const existingReservation = await ctx.db
      .query('reservations')
      .filter((q) => q.eq(q.field('vehicleId'), args.vehicleId))
      .filter((q) =>
        q.and(
          q.lt(q.field('startDate'), args.endDate),
          q.gt(q.field('endDate'), args.startDate),
        ),
      )
      .first();

    if (existingReservation) {
      throw new Error('Vehicle not available for selected dates');
    }

    // Create reservation
    return await ctx.db.insert('reservations', {
      vehicleId: args.vehicleId,
      userId: identity.subject,
      startDate: args.startDate,
      endDate: args.endDate,
      status: 'confirmed',
    });
  },
});
```

Remember to always prioritize user experience, security, and performance in your implementations. Follow these rules to maintain code quality and consistency across the project.
