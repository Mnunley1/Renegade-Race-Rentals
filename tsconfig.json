{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@renegade/convex/*": ["./packages/convex-shared/convex/*"]
    }
  },
  "files": [],
  "references": [
    { "path": "./apps/Renegade Race App" },
    { "path": "./apps/Renegade-Race-Web-App" },
    { "path": "./apps/Renegade-Rentals-Admin-App" },
    { "path": "./packages/convex-shared" }
  ]
}
